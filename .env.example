# ============================================================
# DEFAULT V1 API SET
# Required for the first real connected CrisisCoord build.
# ============================================================

# Band is required for the shared crisis room and five-agent handoff flow.
BAND_API_BASE_URL=https://app.band.ai/api/v1/agent
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_ASSESSMENT_ID=
BAND_AGENT_ASSESSMENT_KEY=
BAND_AGENT_LEGAL_ID=
BAND_AGENT_LEGAL_KEY=
BAND_AGENT_TECHNICAL_ID=
BAND_AGENT_TECHNICAL_KEY=
BAND_AGENT_COMMUNICATIONS_ID=
BAND_AGENT_COMMUNICATIONS_KEY=
BAND_AGENT_ESCALATION_ID=
BAND_AGENT_ESCALATION_KEY=

# Supabase is the system of record for incidents, audit, decisions, evidence,
# notification state, provider health, and auth once we leave seeded local mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Model runtime settings.
MODEL_PROVIDER=aimlapi
MODEL_TIMEOUT_MS=45000
MODEL_MAX_RETRIES=2

# AI/ML API is the main-path model provider required for agent reasoning.
AIML_API_BASE_URL=https://api.aimlapi.com/v1
AI_ML_API_KEY=
AIML_DEFAULT_MODEL=google/gemma-3-4b-it

# Featherless is required as the visible open-model / partner route.
FEATHERLESS_API_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_API_KEY=
FEATHERLESS_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# ============================================================
# DEFAULT OPTIONAL API
# Use only if we want real test email in v1. Otherwise keep sends simulated.
# ============================================================

EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TEST_RECIPIENT=

# ============================================================
# ADD-ON: PUBLIC LIVE-DATA SOURCES
# Useful for real evidence enrichment. Not required for v1 app usability.
# Most can run without keys or with optional keys for rate limits.
# ============================================================

CISA_KEV_JSON_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_KEV_GITHUB_JSON_URL=https://raw.githubusercontent.com/cisagov/kev-data/develop/known_exploited_vulnerabilities.json
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json
NVD_API_KEY=
FIRST_EPSS_API_BASE_URL=https://api.first.org/data/v1
OSV_API_BASE_URL=https://api.osv.dev/v1
GITHUB_ADVISORIES_API_BASE_URL=https://api.github.com
GITHUB_ADVISORIES_TOKEN=
SEC_EDGAR_API_BASE_URL=https://data.sec.gov
SEC_EDGAR_USER_AGENT=CrisisCoord demo contact@example.com
OPENFDA_API_BASE_URL=https://api.fda.gov

# ============================================================
# ADD-ON: KEYED THREAT INTELLIGENCE
# Optional deeper IOC enrichment. Do not use customer identifiers in demo.
# ============================================================

OTX_API_BASE_URL=https://otx.alienvault.com/api/v1
OTX_API_KEY=
ABUSEIPDB_API_BASE_URL=https://api.abuseipdb.com/api/v2
ABUSEIPDB_API_KEY=
URLHAUS_API_BASE_URL=https://urlhaus-api.abuse.ch/v1
URLHAUS_AUTH_KEY=

# ============================================================
# ADD-ON: EMAIL PROVIDER ALTERNATIVES
# Choose one only if Resend is not used.
# ============================================================

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
AWS_SES_REGION=
AWS_SES_FROM_EMAIL=

# ============================================================
# ADD-ON: ESCALATION AND ENTERPRISE WORKFLOW CONNECTORS
# Future integrations. Not required for v1 unless the team explicitly chooses
# a live test recipient/channel.
# ============================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TEST_TO=
SLACK_BOT_TOKEN=
SLACK_INCIDENT_CHANNEL_ID=
TEAMS_WEBHOOK_URL=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_EMAIL=
JIRA_API_TOKEN=
SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
